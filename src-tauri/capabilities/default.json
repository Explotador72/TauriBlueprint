{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "run-java", "cmd": "java", "args": ["-jar", "app.jar"] },
        { "name": "bin/template", "sidecar": true }
      ]
    }
  ]
}
